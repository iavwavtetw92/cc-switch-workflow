{
  "name": "cc-switch-pro",
  "version": "1.0.0",
  "description": "快捷开发工作流工具 - 多窗口协同工作流管理",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"tsc -p tsconfig.electron.json -w\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "compile": "tsc -p tsconfig.electron.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:ui": "vitest --config vitest.config.ts --ui"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "element-plus": "^2.5.0",
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.1.0",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.1",
    "vue": "^3.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "happy-dom": "^13.10.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.8.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ccswitch.pro",
    "productName": "CC Switch Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
